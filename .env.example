# Jira Configuration
# For Test Server:
JIRA_BASE_URL="https://test.jira-clst.mts.ru/rest/scriptrunner/latest/custom"
# For Production Server:
# JIRA_BASE_URL="https://jira.mts.ru/"
JIRA_ACCESS_TOKEN="your-jira-personal-token"
JIRA_USERNAME="your-email@company.com"

# Confluence Configuration
# For Test Server:
CONFLUENCE_BASE_URL="https://test.cnfl-clst.mts.ru/rest/scriptrunner/latest/custom"
# For Production Server:
# CONFLUENCE_BASE_URL="https://confluence.mts.ru/"
CONFLUENCE_ACCESS_TOKEN="your-confluence-personal-token"
CONFLUENCE_SPACE="PROJECTS"
CONFLUENCE_SPACE_KEY="PROJECTS"
ROOT_PAGE_ID_TO_ADD_NEW_PAGES=897438835
NEW_PAGE_SPACE="Books"

# Project Configuration
PROJECT_NAME="Stroki.Clone.S3.Integration.Api"
WEB_REQUEST_TIMEOUT_IN_SECONDS=30

# Context Analyzer Configuration
CONTEXT_LANGUAGES="ru,en"
CONTEXT_MIN_RELEVANCE_SCORE=0.3
CONTEXT_MAX_SUMMARY_LENGTH=500

# Logging Configuration
LOG_LEVEL="INFO"
LOG_FILE="logs/mts_agent.log"

# Development Configuration
DEBUG=false
TEST_MODE=false

# Performance Configuration
MAX_CONCURRENT_REQUESTS=10
CACHE_TTL_SECONDS=3600
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=1

# Security Configuration
ENABLE_AUTH=false  # Phase 2 feature
SECRET_KEY="your-secret-key-here"  # Phase 2 feature

# Web Interface Configuration (Phase 2)
IIS_SITE_PORT=17034
HOST="localhost"
PORT=8000

# Employee Monitoring Configuration
JIRA_PROJECT_KEYS="OPENBD,0BF,DEV"
PROTOCOLS_DIRECTORY_PATH="protocols"  # Относительный путь к папке с протоколами
DAILY_REPORTS_DIR="reports/daily"
WEEKLY_REPORTS_DIR="reports/weekly"
WEEKLY_REPORTS_SPACE="TEAM"
DAILY_ANALYSIS_TIME="09:00"
WEEKLY_REPORT_TIME="17:00"
QUALITY_THRESHOLD="0.9"
EMPLOYEE_MONITORING_ENABLED=true

# File Paths Configuration
TASK_ANALYZER_TXT_PATH="stage1_text_analysis.txt"  # Путь к файлу анализа задач (txt)
TASK_ANALYZER_JSON_PATH="stage2_final_json.json"   # Путь к файлу анализа задач (json)

# Git Integration for Employee Monitoring
GIT_ENABLED=true
GIT_REPOSITORIES="https://github.com/company/project1.git,https://github.com/company/project2.git"
COMMIT_ANALYSIS_DAYS=7

# Employee Analytics
EMPLOYEE_TRACKING_ENABLED=true
EXCLUDED_USERS="bot,system,automation"
TRENDS_ANALYSIS_ENABLED=true
PERFORMANCE_METRICS="task_completion_rate,meeting_engagement_score,git_activity_score"
